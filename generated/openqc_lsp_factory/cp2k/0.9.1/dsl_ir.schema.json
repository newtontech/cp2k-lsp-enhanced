{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/newtontech/cp2k-lsp-enhanced/generated/openqc_lsp_factory/cp2k/0.9.1/dsl_ir.schema.json",
  "title": "OpenQC DSL IR",
  "description": "Versioned DSL intermediate-representation artifact produced by the OpenQC LSP factory pipeline.",
  "type": "object",
  "required": [
    "software",
    "version",
    "status",
    "keywords"
  ],
  "additionalProperties": false,
  "properties": {
    "software": {
      "type": "string",
      "minLength": 1,
      "description": "Target software identifier, e.g. 'cp2k'."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Software version this IR was generated for."
    },
    "status": {
      "type": "string",
      "enum": ["success", "review_required"],
      "description": "Generation status; 'review_required' flags low-confidence items."
    },
    "sources": {
      "type": "array",
      "description": "Source manifests used during generation.",
      "items": {
        "type": "object",
        "required": ["source_ref", "kind", "version", "confidence"],
        "additionalProperties": true,
        "properties": {
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "documentation",
              "example",
              "schema",
              "source",
              "release-notes",
              "agent-guidance"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "description": "Extracted keyword entries.",
      "items": {
        "type": "object",
        "required": ["name", "status", "confidence", "source_ref"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Upper-cased keyword name."
          },
          "section": {
            "type": "string",
            "description": "CP2K section the keyword belongs to."
          },
          "type": {
            "type": "string",
            "enum": ["integer", "keyword", "logical", "real", "string", "word"],
            "description": "Data type of the keyword value."
          },
          "enum": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "description": "Allowed values when the keyword is an enumeration."
          },
          "default": {
            "type": "string",
            "description": "Default value for the keyword."
          },
          "unit": {
            "type": "string",
            "description": "Physical unit of the keyword value."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the keyword."
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated", "removed"],
            "description": "Lifecycle status of the keyword."
          },
          "replacement": {
            "type": "string",
            "description": "Suggested replacement keyword for deprecated/removed entries."
          },
          "renamed_from": {
            "type": "string",
            "description": "Original name if this keyword was renamed."
          },
          "source_ref": {
            "type": "string",
            "description": "Reference to the source this keyword was extracted from."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Extraction confidence score (0-1)."
          },
          "version": {
            "type": "string",
            "description": "Software version this keyword entry corresponds to."
          }
        }
      }
    }
  }
}
