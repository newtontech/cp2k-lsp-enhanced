{
  "name": "cp2k-lsp-enhanced",
  "version": "1.0.0",
  "description": "Enhanced Language Server Protocol implementation for CP2K input files",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "start": "node dist/server.js --stdio"
  },
  "keywords": [
    "cp2k",
    "lsp",
    "language-server",
    "quantum-chemistry",
    "molecular-dynamics"
  ],
  "author": "newtontech",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist/**/*",
    "data/**/*",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "cp2k-lsp-enhanced": "./dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/newtontech/cp2k-lsp-enhanced.git"
  }
}
