{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/newtontech/cp2k-lsp-enhanced/sources/manifest.schema.json",
  "title": "OpenQC LSP Source Manifest",
  "type": "object",
  "required": [
    "manifest_version",
    "software",
    "software_version",
    "generated_at",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "integer",
      "minimum": 1
    },
    "software": {
      "type": "string",
      "minLength": 1
    },
    "software_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_ref",
          "kind",
          "version",
          "confidence"
        ],
        "additionalProperties": false,
        "properties": {
          "source_ref": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._/-]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "documentation",
              "example",
              "schema",
              "source",
              "release-notes",
              "agent-guidance"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "string"
          }
        },
        "anyOf": [
          {
            "required": [
              "path"
            ]
          },
          {
            "required": [
              "url"
            ]
          }
        ]
      }
    },
    "dsl_ir": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "keywords": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "status",
              "confidence",
              "source_ref"
            ],
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "section": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "enum": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "default": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "active",
                  "deprecated",
                  "removed"
                ]
              },
              "replacement": {
                "type": "string"
              },
              "renamed_from": {
                "type": "string"
              },
              "source_ref": {
                "type": "string"
              },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    }
  }
}
