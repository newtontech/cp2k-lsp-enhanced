{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CP2K Input",
  "scopeName": "source.cp2k",
  "fileTypes": ["inp", "cp2k"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#sections" },
    { "include": "#keywords" },
    { "include": "#values" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.exclamation.cp2k",
          "match": "^\\s*!.*$"
        },
        {
          "name": "comment.line.number-sign.cp2k",
          "match": "^\\s*#.*$"
        },
        {
          "name": "comment.line.inline.cp2k",
          "match": "(?<!\\S)[!#].*$"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.cp2k",
          "match": "^\\s*(@(?:SET|IF|ELIF|ELSE|ENDIF|INCLUDE))\\b"
        },
        {
          "name": "variable.other.cp2k",
          "match": "\\$\\{[A-Za-z_][A-Za-z0-9_]*\\}"
        },
        {
          "name": "string.quoted.include.cp2k",
          "match": "(?<=@INCLUDE\\s)(?:\"[^\"]+\"|'[^']+'|\\S+)"
        }
      ]
    },
    "sections": {
      "patterns": [
        {
          "name": "entity.name.section.begin.cp2k",
          "match": "^\\s*&(?!(?:END)\\b)([A-Za-z_][A-Za-z0-9_]*)\\b"
        },
        {
          "name": "entity.name.section.end.cp2k",
          "match": "^\\s*&END(?:\\s+([A-Za-z_][A-Za-z0-9_]*))?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "support.type.property-name.cp2k",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:=|\\S))"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "name": "constant.language.boolean.cp2k",
          "match": "\\b(?:T|F|TRUE|FALSE|YES|NO|ON|OFF)\\b"
        },
        {
          "name": "constant.numeric.cp2k",
          "match": "(?<![A-Za-z_])[-+]?\\d+(?:\\.\\d*)?(?:[Ee][-+]?\\d+)?\\b"
        },
        {
          "name": "storage.modifier.unit.cp2k",
          "match": "\\[[A-Za-z_][A-Za-z0-9_/-]*\\]"
        },
        {
          "name": "string.quoted.double.cp2k",
          "match": "\"(?:[^\"\\\\]|\\\\.)*\""
        },
        {
          "name": "string.quoted.single.cp2k",
          "match": "'(?:[^'\\\\]|\\\\.)*'"
        },
        {
          "name": "string.unquoted.path.cp2k",
          "match": "(?<=\\s)(?:\\.\\.?/|/)?[A-Za-z0-9_./+-]+\\.(?:inp|inc|basis|pot|dat|xyz|pdb|restart)\\b"
        }
      ]
    }
  }
}
