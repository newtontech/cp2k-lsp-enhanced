&GLOBAL
  RUN_TYPE ENERGY
&END GLOBAL

&FORCE_EVAL
  METHOD QS
  &DFT
    &MGRID
      CUTOFF 50
    &END MGRID
    &XC
      &XC_FUNCTIONAL
        &PBE
        &END
        &B3LYP
        &END
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      A 10.0 0.0 0.0
    &END CELL
    &COORD
      O 0.0 0.0 0.0
      H 0.757 0.586 0.0
      X 1.0 2.0 3.0
    &END COORD
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
