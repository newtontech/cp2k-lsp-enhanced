&GLOBAL
RUN_TYPE ENERGY
PROJECT fmt_test
&END GLOBAL

&FORCE_EVAL
  METHOD QS
&DFT
  &MGRID
CUTOFF 400
  REL_CUTOFF 80
  &END MGRID
    &XC
    &XC_FUNCTIONAL PBE
    &END XC_FUNCTIONAL
  &END XC
&END DFT
  &SUBSYS
    &CELL
      A 10.0 0.0 0.0
    B 0.0 10.0 0.0
      C 0.0 0.0 10.0
    &END CELL
&COORD
  O 0.0 0.0 0.0
&END COORD
&KIND O
  BASIS_SET DZVP-MOLOPT-SR-GTH
POTENTIAL GTH-PBE-q6
&END KIND
  &END SUBSYS
&END FORCE_EVAL
