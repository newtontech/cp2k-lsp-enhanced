&GLOBAL
  PROJECT geo_test
  RUN_TYPE GEO_OPT
&END GLOBAL
&FORCE_EVAL
  METHOD QS
  &DFT
    &MGRID
      CUTOFF 600
      REL_CUTOFF 60
    &END MGRID
    &QS
      METHOD GAPW
    &END QS
    &SCF
      MAX_SCF 30
      EPS_SCF 1.0E-7
    &END SCF
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
  &END DFT
  &SUBSYS
    &KIND Si
      ELEMENT Si
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE
    &END KIND
    &COORD
      Si 0.0 0.0 0.0
      Si 2.7 2.7 0.0
    &END COORD
    &CELL
      A 5.4 0.0 0.0
      B 0.0 5.4 0.0
      C 0.0 0.0 5.4
      PERIODIC XYZ
    &END CELL
  &END SUBSYS
&END FORCE_EVAL
