&GLOBAL
  PROJECT lint_test
  RUN_TYPE ENERGY
&END GLOBAL
&FORCE_EVAL
  METHOD QS
  &DFT
    &MGRID
      CUTOFF 50
      REL_CUTOFF 10
    &END MGRID
    &SCF
      MAX_SCF 5
      EPS_SCF 1.0E-3
    &END SCF
  &END DFT
  &SUBSYS
    &CELL
      A 10.0 0.0 0.0
      B 0.0 10.0 0.0
      C 0.0 0.0 10.0
    &END CELL
    &COORD
      O 0.0 0.0 0.0
      H 0.9 0.0 0.0
      H -0.9 0.0 0.0
    &END COORD
  &END SUBSYS
&END FORCE_EVAL
