&GLOBAL
  RUN_TYPE ENERGY
&END GLOBAL

&MOTION
  &GEO_OPT
    MAX_ITER 100
  &END GEO_OPT
&END MOTION

&FORCE_EVAL
  METHOD QS
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC XYZ
    &END CELL
    &COORD
      O  0.0  0.0  0.0
      H  0.9  0.0  0.0
      H -0.9  0.0  0.0
    &END COORD
    &KIND O
      BASIS_SET DZVP-MOLOPT-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND H
      BASIS_SET DZVP-MOLOPT-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
  &END SUBSYS
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS
    &QS
      EPS_DEFAULT 1.0E-12
    &END QS
    &POISSON
      PERIODIC XYZ
    &END POISSON
    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
    &SCF
      MAX_SCF 50
      EPS_SCF 1.0E-6
    &END SCF
    &MGRID
      CUTOFF 400
      REL_CUTOFF 40
    &END MGRID
  &END DFT
&END FORCE_EVAL
