&GLOBAL
  RUN_TYPE GEO_OPT
&END GLOBAL

&MOTION
  &GEO_OPT
    MAX_ITER 10
  &END GEO_OPT
&END MOTION

&FORCE_EVAL
  METHOD QS
  &SUBSYS
    &CELL
      ABC 10.0 10.0 10.0
      PERIODIC XYZ
    &END CELL
    &COORD
      X  0.0  0.0  0.0
      H  0.9  0.0  0.0
    &END COORD
  &END SUBSYS
  &DFT
    &XC
      &XC_FUNCTIONAL B3LYP
      &END XC_FUNCTIONAL
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC
    &SCF
      MAX_SCF 10
      EPS_SCF 1.0E-3
      &OT
        PRECONDITIONER FULL_SINGLE_INVERSE
      &END OT
      &DIAGONALIZATION
        ALGORITHM STANDARD
      &END DIAGONALIZATION
    &END SCF
    &MGRID
      CUTOFF 50
      REL_CUTOFF 10
    &END MGRID
  &END DFT
&END FORCE_EVAL
